---
import { SEO, type SEOProps } from "astro-seo";

export interface Props {
    title: string;
    titleTemplate?: string;
    description: string;
    cardTitle?: string;
    article?: { pubDate?: Date };
    image?: {
        url: URL;
        width: number;
        height: number;
        type: string;
        alt: string;
        large: boolean;
    };
    extend?: SEOProps["extend"];
}

const defaultImage: Props["image"] = {
    url: new URL("/assets/laptoppfp2-offwhite-cropped-small.png", Astro.url),
    type: "image/png",
    height: 600,
    width: 600,
    alt: "Profile picture of a cartoon frog typing on a laptop",
    large: false,
};

let {
    title,
    titleTemplate = "Kian Kasad",
    description,
    cardTitle,
    article,
    image = defaultImage,
} = Astro.props;
title = title + " | " + titleTemplate;
---

<SEO
    {title}
    {description}
    openGraph={{
        basic: {
            title: cardTitle ?? title,
            type: article !== undefined ? "article" : "website",
            image: image.url.href,
        },
        image: image,
        optional: { description },
        article: {
            publishedTime: article?.pubDate?.toISOString(),
        },
    }}
    twitter={{
        title: cardTitle ?? title,
        image: image.url,
        imageAlt: image.alt,
        card: image.large ? "summary_large_image" : "summary",
    }}
/>
